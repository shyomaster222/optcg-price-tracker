# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///optcg_prices.db

# Scraper settings
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_REQUESTS_PER_MINUTE=10

# eBay Browse API (optional - enables eBay price scraping when set)
# Get from: https://developer.ebay.com → My Account → Application Keys
# Use App ID + Cert ID for auto token refresh (recommended), or a manual token:
# EBAY_APP_ID=YourApp-PRD-xxxxxxxx-xxxxxxxx
# EBAY_CERT_ID=PRD-xxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxx
# EBAY_ACCESS_TOKEN=your_oauth_token_here

# Daily email (Gmail SMTP)
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password: Google Account → Security → App Passwords
# 3. Use the App Password below (NOT your regular Gmail password)
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
COMPANY_EMAIL=company@example.com
