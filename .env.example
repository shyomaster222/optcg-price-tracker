# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///optcg_prices.db

# Scraper settings
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_REQUESTS_PER_MINUTE=10

# eBay Browse API (optional - enables eBay price scraping when set)
# Get from: https://developer.ebay.com → My Account → Application Keys
# Use App ID + Cert ID for auto token refresh (recommended), or a manual token:
# EBAY_APP_ID=YourApp-PRD-xxxxxxxx-xxxxxxxx
# EBAY_CERT_ID=PRD-xxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxx
# EBAY_ACCESS_TOKEN=your_oauth_token_here

# Daily email (Resend)
# 1. Sign up at resend.com
# 2. Add & verify your domain (rarecardsjapan.com)
# 3. Create an API key and paste it below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
COMPANY_EMAIL=admin@rarecardsjapan.com

# ----------------------------------------------------------------------
# Price sync (RCJ Shopify <- Fuji undercut)
# ----------------------------------------------------------------------
# Create a Shopify CUSTOM APP in the RCJ store (Settings > Apps > Develop apps)
# with Admin API scope write_products (+ read_products) and paste its token here.
SHOPIFY_SHOP=rare-cards-japan.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# Master switches — keep DRY_RUN=true until you've reviewed a real run.
PRICE_SYNC_ENABLED=false
PRICE_SYNC_DRY_RUN=true

# Pricing rule + guardrails (fractions: 0.03 = 3%)
UNDERCUT_PCT=0.03          # target = Fuji x (1 - this)
AUTO_TOLERANCE=0.05        # auto-apply only if |change vs current| <= this
MAX_DROP=0.30             # relative safety floor: never auto-drop more than this
NOOP_EPSILON=0.01         # ignore changes smaller than this fraction ...
NOOP_EPSILON_USD=0.50     # ... and smaller than this many USD
FUJI_FRESH_HOURS=48       # ignore Fuji prices older than this
PRICE_ROUNDING=dollar      # target rounding: dollar (nearest $1) | cent | 99

# Config files (repo-root relative)
PRICE_MAP_PATH=price_map.json
PRICE_FLOORS_PATH=price_floors.json
